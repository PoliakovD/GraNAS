# ============================================================
# vds.env.example — шаблон для локального запуска вручную.
#
# При деплое через CI этот файл НЕ используется:
# CI генерирует vds.env на лету из GitHub Environment Secrets.
#
# Для ручного деплоя:
#   cp vds.env.example vds.env
#   nano vds.env   # заменить все __CHANGE_ME__
#   bash init-letsencrypt.sh
#   docker compose --env-file vds.env -f compose.yaml -f compose.vds.yaml up -d
#
# Требуемые GitHub Environment Secrets (dev-vds / prod-vds):
#   VDS_HOST, VDS_USER, DOMAIN, CERTBOT_EMAIL
#   JWT_SECRET, SHARE_TOKEN_ENCRYPTION_KEY, TURN_SECRET
#   AUTH_POSTGRES_PASSWORD, METADATA_POSTGRES_PASSWORD, LOG_POSTGRES_PASSWORD
#   SHARING_POSTGRES_PASSWORD, SIGNALING_POSTGRES_PASSWORD, NOTIFICATION_POSTGRES_PASSWORD
#   RABBITMQ_DEFAULT_PASS
#   dev-only:  VDS_PASSWORD
#   prod-only: VDS_SSH_KEY, SMTP_HOST, SMTP_PORT, SMTP_USERNAME, SMTP_PASSWORD, SMTP_FROM, SMTP_USE_STARTTLS
# ============================================================

# -------------------- Let's Encrypt --------------------
DOMAIN=__CHANGE_ME__
CERTBOT_EMAIL=__CHANGE_ME__
APP_BASE_URL=__CHANGE_ME__
SHARE_TOKEN_ENCRYPTION_KEY=__CHANGE_ME__

# -------------------- General --------------------
PREFIX=dev
ENVIRONMENT=Development
COMPOSE_PROJECT_NAME=granas-dev

# -------------------- Image versions --------------------
POSTGRES_VERSION=16-alpine
REDIS_VERSION=7.2-alpine
OPENSEARCH_VERSION=3.6.0
OPENSEARCH_JAVA_OPTS="-Xms512m -Xmx512m"
OPENSEARCH_PORT_HOST=9200
OPENSEARCH_PORT_CONTAINER=9200
OPENSEARCH_URI=http://opensearch:9200
RABBITMQ_VERSION=4.3.0

# -------------------- Host ports --------------------
AUTH_POSTGRES_PORT_HOST=5433
METADATA_POSTGRES_PORT_HOST=5434
LOG_POSTGRES_PORT_HOST=5435
POSTGRES_PORT_CONTAINER=5432

REDIS_PORT_HOST=6379
REDIS_PORT_CONTAINER=6379

RABBITMQ_AMQP_PORT_HOST=5672
RABBITMQ_AMQP_PORT_CONTAINER=5672
RABBITMQ_MANAGEMENT_PORT_HOST=15672
RABBITMQ_MANAGEMENT_PORT_CONTAINER=15672

AUTH_SERVICE_PORT_HOST=8081
METADATA_SERVICE_PORT_HOST=8082
LOG_SERVICE_PORT_HOST=8083
SERVICE_PORT_CONTAINER=8080

SHARING_SERVICE_PORT_HOST=8084
SHARING_POSTGRES_PORT_HOST=5436
SIGNALING_POSTGRES_PORT_HOST=5437

# -------------------- Auth DB --------------------
AUTH_POSTGRES_DB=auth_dev
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=__CHANGE_ME__
AUTH_POSTGRES_HOST=postgres-auth

# -------------------- Metadata DB --------------------
METADATA_POSTGRES_DB=metadata_dev
METADATA_POSTGRES_USER=metadata_user
METADATA_POSTGRES_PASSWORD=__CHANGE_ME__
METADATA_POSTGRES_HOST=postgres-metadata

# -------------------- Log DB --------------------
LOG_POSTGRES_DB=logs_dev
LOG_POSTGRES_USER=log_user
LOG_POSTGRES_PASSWORD=__CHANGE_ME__
LOG_POSTGRES_HOST=postgres-log

# -------------------- Redis --------------------
REDIS_HOST=redis
REDIS_CONNECTION_STRING=redis:6379

# -------------------- RabbitMQ --------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_DEFAULT_USER=granas_dev
RABBITMQ_DEFAULT_PASS=__CHANGE_ME__

# -------------------- JWT --------------------
JWT_SECRET=__CHANGE_ME__
JWT_ISSUER=GraNAS
JWT_AUDIENCE=GraNASClients
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# -------------------- Sharing DB --------------------
SHARING_POSTGRES_DB=sharing_dev
SHARING_POSTGRES_USER=sharing_user
SHARING_POSTGRES_PASSWORD=__CHANGE_ME__
SHARING_POSTGRES_HOST=postgres-sharing

# -------------------- Service images --------------------
AUTH_SERVICE_IMAGE=granas-auth-api
AUTH_SERVICE_VERSION=latest
METADATA_SERVICE_IMAGE=granas-metadata-api
METADATA_SERVICE_VERSION=latest
LOG_SERVICE_IMAGE=granas-log-api
LOG_SERVICE_VERSION=latest
SHARING_SERVICE_IMAGE=granas-sharing-api
SHARING_SERVICE_VERSION=latest
SIGNALING_SERVICE_IMAGE=granas-signaling-api
SIGNALING_SERVICE_VERSION=latest
NOTIFICATION_SERVICE_IMAGE=granas-notification-api
NOTIFICATION_SERVICE_VERSION=latest
GATEWAY_SERVICE_IMAGE=granas-gateway
GATEWAY_SERVICE_VERSION=latest
WEB_CLIENT_IMAGE=granas-web-client
WEB_CLIENT_VERSION=latest

# -------------------- Connection strings --------------------
AUTH_DB_CONNECTION_STRING=Host=postgres-auth;Port=5432;Database=auth_dev;Username=auth_user;Password=__CHANGE_ME__
METADATA_DB_CONNECTION_STRING=Host=postgres-metadata;Port=5432;Database=metadata_dev;Username=metadata_user;Password=__CHANGE_ME__
LOG_DB_CONNECTION_STRING=Host=postgres-log;Port=5432;Database=logs_dev;Username=log_user;Password=__CHANGE_ME__
SHARING_DB_CONNECTION_STRING=Host=postgres-sharing;Port=5432;Database=sharing_dev;Username=sharing_user;Password=__CHANGE_ME__

# -------------------- API Gateway --------------------
GATEWAY_PORT_HOST=8080
WEB_CLIENT_ORIGIN=https://__CHANGE_ME__

# -------------------- Web client --------------------
WEB_CLIENT_PORT_HOST=5173
VITE_API_BASE_URL=https://__CHANGE_ME__

# -------------------- Signaling DB --------------------
SIGNALING_POSTGRES_DB=signalingdb
SIGNALING_POSTGRES_USER=signaling
SIGNALING_POSTGRES_PASSWORD=__CHANGE_ME__
SIGNALING_POSTGRES_HOST=postgres-signaling
SIGNALING_DB_CONNECTION_STRING=Host=postgres-signaling;Port=5432;Database=signalingdb;Username=signaling;Password=__CHANGE_ME__

# -------------------- Signaling Service --------------------
SIGNALING_SERVICE_PORT_HOST=8085
SIGNALING_REDIS_CONNECTION_STRING=redis:6379,defaultDatabase=2
SIGNALING_TTL_SECONDS=600

# -------------------- TURN (coturn) --------------------
TURN_SECRET=__CHANGE_ME__
TURN_REALM=__CHANGE_ME__
# Публичный IP VDS (нужен для WebRTC P2P и для --external-ip котурна)
TURN_HOST=__CHANGE_ME__
EXTERNAL_IP=__CHANGE_ME__
TURN_PORT=3478

# -------------------- Notification DB --------------------
NOTIFICATION_POSTGRES_DB=notification_dev
NOTIFICATION_POSTGRES_USER=notification_user
NOTIFICATION_POSTGRES_PASSWORD=__CHANGE_ME__
NOTIFICATION_POSTGRES_HOST=postgres-notification
NOTIFICATION_POSTGRES_PORT_HOST=5438
NOTIFICATION_DB_CONNECTION_STRING=Host=postgres-notification;Port=5432;Database=notification_dev;Username=notification_user;Password=__CHANGE_ME__

# -------------------- Notification Service --------------------
NOTIFICATION_SERVICE_PORT_HOST=8086

# -------------------- SMTP (dev: mailpit / prod: настоящий SMTP) --------------------
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@granas.local
SMTP_USE_STARTTLS=false
