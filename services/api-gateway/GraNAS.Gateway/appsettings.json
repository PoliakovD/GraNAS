{
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp.ReverseProxy": "Warning",
        "System": "Warning"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth",
        "Match": {
          "Path": "/api/auth/{**remainder}"
        },
        "Transforms": [
          { "ResponseHeaderRemove": "Access-Control-Allow-Origin" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Methods" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Headers" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Credentials" }
        ]
      },
      "metadata-route": {
        "ClusterId": "metadata",
        "Match": {
          "Path": "/api/metadata/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**remainder}" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Origin" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Methods" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Headers" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Credentials" }
        ]
      },
      "sharing-route": {
        "ClusterId": "sharing",
        "Match": {
          "Path": "/api/sharing/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**remainder}" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Origin" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Methods" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Headers" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Credentials" }
        ]
      },
      "signaling-api-route": {
        "ClusterId": "signaling",
        "Match": {
          "Path": "/api/signaling/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**remainder}" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Origin" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Methods" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Headers" },
          { "ResponseHeaderRemove": "Access-Control-Allow-Credentials" }
        ]
      },
      "signaling-hub-route": {
        "ClusterId": "signaling",
        "Match": {
          "Path": "/hubs/signaling/{**remainder}"
        }
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": {
          "d1": { "Address": "" }
        }
      },
      "metadata": {
        "Destinations": {
          "d1": { "Address": "" }
        }
      },
      "sharing": {
        "Destinations": {
          "d1": { "Address": "" }
        }
      },
      "signaling": {
        "Destinations": {
          "d1": { "Address": "" }
        }
      }
    }
  }
}
