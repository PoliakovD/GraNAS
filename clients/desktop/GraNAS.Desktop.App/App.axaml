<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GraNAS.Desktop.App.App"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://Semi.Avalonia/SemiTheme.axaml" />
        <StyleInclude Source="/Assets/Themes/SemiOverrides.axaml" />
    </Application.Styles>
</Application>
