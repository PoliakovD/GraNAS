<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style>
        <Style.Resources>
            <!-- Brand purple matching web client #722ed1 -->
            <Color x:Key="SystemAccentColor">#722ed1</Color>
            <SolidColorBrush x:Key="SystemAccentColorBrush" Color="#722ed1" />
        </Style.Resources>
    </Style>
</Styles>
