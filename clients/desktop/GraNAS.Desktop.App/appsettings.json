{
  "ApiGateway": {
    "BaseUrl": "http://granas.ru:8080"
  },
  "Signaling": {
    "HubPath": "/hubs/signaling"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "SIPSorcery": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "%LocalAppData%/GraNAS/logs/desktop-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  }
}
