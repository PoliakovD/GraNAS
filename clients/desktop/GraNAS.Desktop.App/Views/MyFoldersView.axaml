<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GraNAS.Desktop.App.ViewModels"
             xmlns:svc="using:GraNAS.Desktop.App.Services.Folders"
             x:DataType="vm:MyFoldersViewModel"
             x:Class="GraNAS.Desktop.App.Views.MyFoldersView">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="16,12">
            <TextBlock Text="Мои папки" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="+ Создать папку"
                    Command="{Binding CreateRootCommand}"
                    Background="#722ed1"
                    Foreground="White"
                    Margin="8,0,0,0" />
            <Button Content="↻"
                    Command="{Binding LoadCommand}"
                    ToolTip.Tip="Обновить" />
        </StackPanel>

        <!-- Folder tree -->
        <ScrollViewer Grid.Row="1" Margin="16,0">
            <TreeView ItemsSource="{Binding Roots}"
                      SelectedItem="{Binding SelectedNode}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate DataType="svc:FolderNode"
                                      ItemsSource="{Binding Children}">
                        <Grid ColumnDefinitions="*,Auto" Margin="2">
                            <TextBlock Text="{Binding Folder.Name}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button Content="Открыть"
                                        Command="{Binding $parent[TreeView].((vm:MyFoldersViewModel)DataContext).OpenCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="6,2" />
                                <Button Content="+ Подпапка"
                                        Command="{Binding $parent[TreeView].((vm:MyFoldersViewModel)DataContext).CreateSubfolderCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="6,2" />
                                <Button Content="✕"
                                        Command="{Binding $parent[TreeView].((vm:MyFoldersViewModel)DataContext).DeleteCommand}"
                                        CommandParameter="{Binding}"
                                        Foreground="Red"
                                        Background="Transparent"
                                        Padding="6,2"
                                        ToolTip.Tip="Удалить папку и все вложенные" />
                                <Button Content="📁 P2P"
                                        Command="{Binding $parent[TreeView].((vm:MyFoldersViewModel)DataContext).BindLocalFolderCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="6,2"
                                        ToolTip.Tip="Привязать локальную папку для P2P-доступа" />
                            </StackPanel>
                        </Grid>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </ScrollViewer>

        <!-- Device folder bindings -->
        <Expander Grid.Row="2"
                  Header="Привязки на этом устройстве"
                  Margin="16,4,16,0"
                  IsExpanded="False">
            <ItemsControl ItemsSource="{Binding LocalBindings}" Margin="0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:LocalBindingRow">
                        <Grid ColumnDefinitions="*,2*,Auto" Margin="0,2">
                            <TextBlock Text="{Binding FolderName}"
                                       VerticalAlignment="Center" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding LocalPath}"
                                       Foreground="Gray"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="2"
                                    Content="Отвязать"
                                    Command="{Binding $parent[ItemsControl].((vm:MyFoldersViewModel)DataContext).ReleaseBindingCommand}"
                                    CommandParameter="{Binding}"
                                    Padding="6,2" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <!-- Loading indicator -->
        <TextBlock Grid.Row="3"
                   Text="Загрузка..."
                   IsVisible="{Binding IsLoading}"
                   Foreground="Gray"
                   Margin="16,8" />

    </Grid>
</UserControl>
