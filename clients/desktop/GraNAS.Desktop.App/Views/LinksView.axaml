<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GraNAS.Desktop.App.ViewModels"
             x:DataType="vm:LinksViewModel"
             x:Class="GraNAS.Desktop.App.Views.LinksView">

    <Grid RowDefinitions="Auto,*">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="24,16,24,12">
            <TextBlock Text="Ссылки" FontSize="22" FontWeight="Bold"
                       VerticalAlignment="Center" />
            <Button Classes="ghost sm" Content="↻"
                    Command="{Binding LoadCommand}" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  Margin="24,0,24,16"
                  ItemsSource="{Binding Links}"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Папка" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="8,4" Spacing="2">
                                <TextBlock Text="{Binding FolderName}" FontWeight="SemiBold"
                                           FontSize="13" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ShareUrl}" FontSize="11"
                                           Foreground="{DynamicResource Ink500Brush}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding ShareUrl}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Истекает"
                                    Binding="{Binding ExpiresAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                    Width="120" />

                <DataGridTemplateColumn Header="Статус" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Classes="tag green" Margin="8,4"
                                    IsVisible="{Binding !Revoked}">
                                <TextBlock Text="активна" FontSize="11"
                                           Foreground="{DynamicResource SuccessBrush}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Действия" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4">
                                <Button Classes="ghost sm" Content="Копировать"
                                        IsEnabled="{Binding ShareUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        Command="{Binding $parent[DataGrid].((vm:LinksViewModel)DataContext).CopyCommand}"
                                        CommandParameter="{Binding}" />
                                <Button Classes="danger sm" Content="Отозвать"
                                        IsVisible="{Binding !Revoked}"
                                        Command="{Binding $parent[DataGrid].((vm:LinksViewModel)DataContext).RevokeCommand}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>

</UserControl>
