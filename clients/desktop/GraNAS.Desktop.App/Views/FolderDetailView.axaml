<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GraNAS.Desktop.App.ViewModels"
             x:DataType="vm:FolderDetailViewModel"
             x:Class="GraNAS.Desktop.App.Views.FolderDetailView">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="16,12" Spacing="4">
            <TextBlock Text="{Binding Folder.Name}"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding Folder.Id, StringFormat='ID: {0}'}"
                       Foreground="{DynamicResource Ink500Brush}"
                       FontSize="11" />
        </StackPanel>

        <!-- Tabs -->
        <TabControl Grid.Row="1">

            <!-- Permissions tab -->
            <TabItem Header="Доступ">
                <Grid RowDefinitions="Auto,*" Margin="16">

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <TextBlock Text="Пользователи с доступом"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Content="+ Выдать доступ"
                                Classes="brand sm"
                                Command="{Binding Permissions.GrantCommand}" />
                        <Button Classes="ghost sm" Content="↻"
                                Command="{Binding Permissions.LoadCommand}" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Permissions.Permissions}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                    <TextBlock Text="{Binding Email}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding UserId}"
                                               Foreground="{DynamicResource Ink500Brush}"
                                               FontSize="11"
                                               IsVisible="{Binding Email, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                               VerticalAlignment="Center"
                                               Margin="8,0" />
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource BrandPrimarySoftBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Margin="8,0">
                                        <TextBlock Text="{Binding AccessLevel}"
                                                   Foreground="{DynamicResource BrandPrimaryBrush}"
                                                   FontSize="11" />
                                    </Border>
                                    <Button Grid.Column="3"
                                            Content="Отозвать"
                                            Classes="danger"
                                            Command="{Binding $parent[ListBox].((vm:PermissionsListViewModel)DataContext).RevokeCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>
            </TabItem>

            <!-- Shares tab -->
            <TabItem Header="Share-ссылки">
                <Grid RowDefinitions="Auto,*" Margin="16">

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <TextBlock Text="Ссылки для общего доступа"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Content="+ Создать ссылку"
                                Classes="brand sm"
                                Command="{Binding Shares.CreateCommand}" />
                        <Button Classes="ghost sm" Content="↻"
                                Command="{Binding Shares.LoadCommand}" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Shares.Shares}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding ExpiresAt, StringFormat='Истекает: {0:d}'}" />
                                        <TextBlock Text="[отозвана]"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   FontSize="11"
                                                   IsVisible="{Binding Revoked}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Отозвать"
                                            Classes="danger"
                                            Command="{Binding $parent[ListBox].((vm:SharesListViewModel)DataContext).RevokeCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding !Revoked}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>
            </TabItem>

            <!-- Properties tab -->
            <TabItem Header="Свойства">
                <ScrollViewer Margin="16">
                    <StackPanel Spacing="16">

                        <!-- About folder -->
                        <Border Classes="stat-card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="О папке" FontWeight="SemiBold" FontSize="13" />

                                <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ID"
                                               Foreground="{DynamicResource Ink500Brush}" FontSize="13" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Properties.FolderIdShort}"
                                               FontFamily="{DynamicResource FontMono}" FontSize="12" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Создана"
                                               Foreground="{DynamicResource Ink500Brush}" FontSize="13" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding Properties.CreatedAt}" FontSize="13" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Изменена"
                                               Foreground="{DynamicResource Ink500Brush}" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding Properties.UpdatedAt}" FontSize="13" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Владелец"
                                               Foreground="{DynamicResource Ink500Brush}" FontSize="13" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding Properties.OwnerDisplay}"
                                               FontSize="13" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Bound device (owner only) -->
                        <Border Classes="stat-card"
                                IsVisible="{Binding Properties.IsOwner}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Устройство" FontWeight="SemiBold" FontSize="13" />

                                <Grid ColumnDefinitions="*,Auto"
                                      IsVisible="{Binding Properties.HasDevice}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Properties.DeviceName}"
                                                   FontWeight="SemiBold" FontSize="13" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="7" Height="7"
                                                     Fill="{DynamicResource SuccessBrush}"
                                                     IsVisible="{Binding Properties.DeviceIsOnline}"
                                                     VerticalAlignment="Center" />
                                            <Ellipse Width="7" Height="7"
                                                     Fill="{DynamicResource Ink300Brush}"
                                                     IsVisible="{Binding !Properties.DeviceIsOnline}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Properties.DeviceIsOnline,
                                                       StringFormat='{}{0}'}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource Ink500Brush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="ghost danger sm"
                                            Content="Отвязать"
                                            Command="{Binding Properties.ReleaseDeviceCommand}" />
                                </Grid>

                                <TextBlock Text="Папка не привязана к устройству."
                                           IsVisible="{Binding !Properties.HasDevice}"
                                           Foreground="{DynamicResource Ink500Brush}"
                                           FontSize="13" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
